FROM registry.access.redhat.com/ubi9/nodejs-20:latest

USER 0
WORKDIR /opt/app-root/src

COPY request-stress-fallback/package.json request-stress-fallback/package-lock.json ./
RUN npm ci --omit=dev

COPY request-stress-fallback/src ./src

RUN chown -R 1001:0 /opt/app-root/src
USER 1001

ENV PORT=5001
EXPOSE 5001

CMD ["node", "src/server.js"]
